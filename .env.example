# Copy to .env and fill in. The bot auto-loads .env next to package.json
# when run via `node src/index.ts`. In Docker, mount these via env_file:
# instead.

# ─── Telegram notifications (required) ────────────────────────────────
# Bot token from @BotFather; chat id of the user / group that receives
# success / failure reports.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── ТГК-1 portal (optional — enable by setting TGC1_LOGIN) ───────────
# Account credentials for tgc1.ru. Leave blank to disable the portal.
TGC1_LOGIN=
TGC1_PASSWORD=

# ─── pesc.ru portal (optional — enable by setting PESC_LOGIN) ─────────
# Account credentials for ikus.pesc.ru / Петроэлектросбыт.
PESC_LOGIN=
PESC_PASSWORD=
# Base32 TOTP secret for unattended 2FA (the string behind the QR code
# when you enable 2FA in the portal). Required if the account has 2FA on.
PESC_TOTP_SECRET=
# HTTP CONNECT / SOCKS5 proxy URL. pesc.ru geo-blocks non-RU egress, so
# from outside Russia you need a Russian exit. Leave blank to go direct.
# Example: http://sing-box-ru:7890
PESC_PROXY_URL=

# ─── Runtime knobs ────────────────────────────────────────────────────
# Where the SQLite state file lives. Defaults to /app/data (matches the
# Docker image's VOLUME). Override locally to e.g. ./data.
METERS_DATA_DIR=

# IANA timezone for the day-of-month scheduling gate. Defaults to the
# host TZ; production sets this to Europe/Moscow.
TZ=Europe/Moscow

# pino log level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info
